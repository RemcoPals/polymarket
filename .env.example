# ─── Kalshi API Credentials ───────────────────────────────────────────────────
# How to get:
#   1. Go to kalshi.com → Profile (top-right) → Settings → API Keys → Create Key
#   2. Copy the Key ID (UUID) shown in the dashboard
#   3. Download the private key .pem file

KALSHI_API_KEY=your-uuid-key-id-here

# Option A — path to your downloaded .pem file (recommended for local use)
KALSHI_PRIVATE_KEY_PATH=/path/to/your/private-key.pem

# Option B — inline PEM string (recommended for fly.io secrets / cloud deploy)
# Replace real newlines with \n when pasting into an env var:
#   awk 'NF {printf "%s\\n", $0}' private-key.pem
# KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# ─── Strategy Parameters ──────────────────────────────────────────────────────
# Minimum consecutive streak before placing a reversal bet
MIN_STREAK=3

# How many recent resolved markets to look back at
LOOKBACK=10

# ─── Kelly Criterion ──────────────────────────────────────────────────────────
# Backtested win rate on Kalshi 15-min BTC markets (streak >= 3): 56.8%
# Use a conservative estimate — do not set higher than your actual backtest result
ESTIMATED_WIN_PROB=0.53

# Fraction of full Kelly to bet (0.5 = half-Kelly, recommended for safety)
KELLY_MULTIPLIER=0.5

# Hard cap: never bet more than this fraction of your bankroll per trade
MAX_BET_PCT=0.05

# ─── Safety ───────────────────────────────────────────────────────────────────
# Always start with DRY_RUN=true to verify signals before using real money
DRY_RUN=true

# Simulated starting balance used for Kelly sizing during dry runs
DRY_RUN_BANKROLL=100

# Bot will stop betting for the day once losses exceed this amount (in USD)
MAX_DAILY_LOSS_USDC=50
