# Kalshi API credentials
# How to get: kalshi.com -> Profile (top-right) -> Settings -> API Keys -> Create Key
# You'll receive a Key ID (UUID) and a private RSA key file (.pem)
KALSHI_API_KEY=your-uuid-key-id-here

# Option A: path to your downloaded .pem file (easiest)
KALSHI_PRIVATE_KEY_PATH=/path/to/your/private-key.pem

# Option B: paste the PEM inline (replace actual newlines with \n)
# KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# Strategy
MIN_STREAK=3
LOOKBACK=10

# Kelly criterion
# estimated_win_prob: conservative estimate from backtests (Kalshi 15-min: 56.8%)
ESTIMATED_WIN_PROB=0.53
KELLY_MULTIPLIER=0.5     # half-Kelly for safety
MAX_BET_PCT=0.05         # never bet more than 5% of bankroll per trade

# Safety — always start with DRY_RUN=true to verify logic before real money
DRY_RUN=true
DRY_RUN_BANKROLL=100     # simulated bankroll for dry-run Kelly sizing
MAX_DAILY_LOSS_USDC=50
