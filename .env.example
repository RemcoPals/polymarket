# ─── Kalshi API Credentials ───────────────────────────────────────────────────
# How to get:
#   1. Go to kalshi.com → Profile (top-right) → Settings → API Keys → Create Key
#   2. Copy the Key ID (UUID) shown in the dashboard
#   3. Download the private key .pem file

KALSHI_API_KEY=your-uuid-key-id-here

# Option A — path to your downloaded .pem file (recommended for local use)
KALSHI_PRIVATE_KEY_PATH=/path/to/your/private-key.pem

# Option B — inline PEM string (recommended for fly.io secrets / cloud deploy)
# Replace real newlines with \n when pasting into an env var:
#   awk 'NF {printf "%s\\n", $0}' private-key.pem
# KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----

# ─── Strategy Parameters ──────────────────────────────────────────────────────
# Minimum consecutive streak before placing a reversal bet (3 recommended)
MIN_STREAK=3

# Per-asset streak overrides (takes priority over MIN_STREAK)
# ETH_MIN_STREAK=3
# BTC_MIN_STREAK=3
# SOL_MIN_STREAK=3
# XRP_MIN_STREAK=3

# How many recent resolved markets to look back at
LOOKBACK=10

# ─── Kelly Criterion ──────────────────────────────────────────────────────────
# Edge above the market price used to estimate win probability
# Backtested: ETH streak ≥3 → ~56.2% on Polymarket, ~56.7% on Binance 1y
SIGNAL_EDGE=0.06

# Fraction of full Kelly to bet (0.5 = half-Kelly, recommended for safety)
KELLY_MULTIPLIER=0.5

# Hard cap: never bet more than this fraction of your bankroll per trade
MAX_BET_PCT=0.06

# ─── Safety ───────────────────────────────────────────────────────────────────
# Always start with DRY_RUN=true to verify signals before using real money
DRY_RUN=true

# Simulated starting balance used for Kelly sizing during dry runs
DRY_RUN_BANKROLL=100

# Bot stops betting for the day once cumulative losses exceed this fraction
MAX_DAILY_LOSS_PCT=0.33

# ─── Strategy F: Tiered Kelly by Streak Length ────────────────────────────────
# Longer streaks → higher accuracy → higher edge → larger Kelly bet.
# Defaults (calibrated from ETH Binance 1y): streak 3-4 → 0.056; streak 5+ → 0.080
# These are hardcoded in bots/config.py — recalibrate via notebooks/strategy_research.ipynb

# ─── Strategy C: Previous-Candle Magnitude Filter ─────────────────────────────
# Only applies a magnitude bonus edge when |log(close/open)| of the previous
# 15-min Binance candle exceeds MAGNITUDE_THRESHOLD_SIGMA × per-asset sigma.
# Backtested: >1σ threshold → OOS 58.8% accuracy (vs 55% baseline).
# Run notebooks/strategy_research.ipynb to validate before enabling.

USE_MAGNITUDE_FILTER=false

# How many σ the previous candle must exceed to trigger the bonus
MAGNITUDE_THRESHOLD_SIGMA=1.0

# Edge bonus added when magnitude threshold is met
MAGNITUDE_BONUS_EDGE=0.023

# Per-asset 15-min |log return| σ — recalibrate quarterly via strategy_research.ipynb
# ETH_SIGMA_15MIN=0.0037
# BTC_SIGMA_15MIN=0.0040
# SOL_SIGMA_15MIN=0.0060
# XRP_SIGMA_15MIN=0.0055

# ─── Dynamic Exit (TP/SL within the 15-min window) ───────────────────────────
# Run notebooks/dynamic_exit_analysis.ipynb first to validate parameters.
# Keep ENABLE_DYNAMIC_EXIT=false until the notebook confirms positive EV.

ENABLE_DYNAMIC_EXIT=false

# Take-profit: sell if contract reprices this many cents in our favour (e.g. 50c → 60c)
TP_CENTS=10

# Stop-loss: sell if contract moves this many cents against us (e.g. 50c → 40c)
SL_CENTS=10

# Don't check exits during first N seconds (avoid noise at market open)
MIN_HOLD_SECS=60

# Price poll interval in seconds (30s = ~26 checks per 15-min window)
POLL_INTERVAL_SECS=30
